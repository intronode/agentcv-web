# .env.example — AgentCV environment variables
#
# The app boots with ZERO env vars locally (dev and production-build modes).
# These variables are for production deployments or optional features.
# Copy the ones you need to .env.local (never commit .env.local).

# ── Auth ─────────────────────────────────────────────────────────────────────

# AUTH_SECRET
# REQUIRED for production deploy. Local dev/prod-build auto-uses an insecure
# fallback and warns; any recognized cloud platform (Vercel, CF_PAGES) will
# throw if this is absent.
# Generate: openssl rand -base64 32
AUTH_SECRET=

# AUTH_TRUST_HOST
# Set "true" in production if NOT on Vercel (Vercel infers it automatically).
# Auto-true locally. Set this when self-hosting behind a reverse proxy.
# AUTH_TRUST_HOST=true

# AUTH_URL
# Optional. Production base URL for auth callbacks (e.g. https://agentcv.ai).
# Setting this also satisfies host-trust on non-Vercel hosts.
# AUTH_URL=https://agentcv.ai

# ── OAuth providers (cloud-only, optional) ───────────────────────────────────

# AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET
# CLOUD-ONLY, optional. Google sign-in button only appears when both are set.
# Omitted silently if absent — dev-credentials sign-in is available instead.
# See docs/AUTH.md for setup instructions.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ── Dev / QA ─────────────────────────────────────────────────────────────────

# DEV_LOGIN
# Optional. Forces the dev credentials sign-in on (1) or off (0).
# Default: on when NODE_ENV != production, off in production.
# Set DEV_LOGIN=1 in prod-mode QA pipelines (qa-shoot.sh sets this).
# DEV_LOGIN=1

# ── Features ─────────────────────────────────────────────────────────────────

# SANITIZER_KEY
# Optional. 64 hex chars (AES-256-GCM key) to enable encrypted storage of
# owner confidential deny-list terms. The feature self-disables if absent
# (UI renders a "not configured" notice; reads return empty list).
# Generate: openssl rand -hex 32
# SANITIZER_KEY=

# ── Server ───────────────────────────────────────────────────────────────────

# PORT
# Optional. Dev/start port (default 3000).
# PORT=3000

# ── Platform gates (set by cloud platforms automatically) ────────────────────
# These are set by hosting platforms, not by you. Listed for reference only.
#
# VERCEL=1          — set by Vercel; enables host trust + production secret gate
# VERCEL_ENV=...    — set by Vercel (production | preview | development)
# CF_PAGES=1        — set by Cloudflare Pages; enables host trust + secret gate
# AGENTCV_PRODUCTION=1  — override: treat this runtime as a cloud deploy
#                         (use when self-hosting and the above vars are absent)
